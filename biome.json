{
    "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noUnknownAtRules": "off",
                "noArrayIndexKey": "off"
            },
            "a11y": "off"
        },
        "domains": {
            "react": "recommended"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "javascript": {
        "formatter": {
            "semicolons": "asNeeded"
        }
    },
    "css": {
        "parser": {
            "cssModules": false,
            "tailwindDirectives": true
        }
    }
}
